{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [".env.example", "tsconfig.base.json"],
  "globalEnv": [
    "DATABASE_URL",
    "DATABASE_URL_UNPOOLED",
    "BLOB_READ_WRITE_TOKEN",
    "ANTHROPIC_API_KEY",
    "GOOGLE_GENERATIVE_AI_API_KEY",
    "LLM_PROVIDER",
    "OPENAI_API_KEY",
    "CLERK_SECRET_KEY",
    "NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY",
    "NEXT_PUBLIC_APP_URL"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "test:leakage": {
      "dependsOn": ["^build"]
    },
    "evals:run": {
      "cache": false,
      "dependsOn": ["^build"]
    },
    "evals:quick": {
      "cache": false,
      "dependsOn": ["^build"]
    },
    "evals:mock-metabolic": {
      "cache": false,
      "dependsOn": ["^build"]
    },
    "db:check": {
      "cache": false
    },
    "clean": {
      "cache": false
    }
  }
}
