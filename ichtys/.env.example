# =============================================================================
# Ichtys — environment variables
# Copiá este archivo a .env.local (apps/web) y/o .env (raíz) y completá valores.
# NUNCA commitear valores reales. Ver docs/SECURITY.md.
# =============================================================================

# --- Auth (Clerk Organizations) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# --- Database (Neon Postgres + pgvector) ---
# Pooled connection (runtime / serverless)
DATABASE_URL=
# Direct/unpooled connection (migrations)
DATABASE_URL_UNPOOLED=

# --- Storage (Vercel Blob) ---
BLOB_READ_WRITE_TOKEN=

# Cifrado de API keys por organización (obligatorio en producción si usan Ajustes → keys)
ORG_LLM_KEYS_ENCRYPTION_SECRET=
# Titulares: Claude, OpenAI. Backups: Gemini (gratis), Groq, GLM vía OpenRouter.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
# auto = Claude → OpenAI → Gemini → Groq → GLM (salta proveedores sin key)
LLM_PROVIDER=auto
# Embeddings RAG (text-embedding-3-small, 1536 dims) — usa OPENAI_API_KEY

# --- Rate limiting (Upstash Redis / Vercel KV REST) ---
# Production should configure either KV_* or UPSTASH_* values.
KV_REST_API_URL=
KV_REST_API_TOKEN=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Set to "false" to disable rate limiting (useful for tests and local dev).
# Defaults to enabled (true) when not set.
RATE_LIMIT_ENABLED=true
# Per-endpoint limits (requests per minute per userId). Defaults shown.
RATE_LIMIT_CHAT_PER_MINUTE=30
RATE_LIMIT_UPLOAD_PER_MINUTE=10
RATE_LIMIT_HISTORY_PER_MINUTE=100
RATE_LIMIT_CITATIONS_PER_MINUTE=100

# --- Internal endpoints ---
# Off by default. Must be explicitly set to true server-side.
ENABLE_INTERNAL_RAG_ANSWER_TEST=false

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
