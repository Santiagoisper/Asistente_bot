# =============================================================================
# Ichtys — environment variables
# Copiá este archivo a .env.local (apps/web) y/o .env (raíz) y completá valores.
# NUNCA commitear valores reales. Ver docs/SECURITY.md.
# =============================================================================

# --- Auth (Clerk Organizations) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# --- Database (Neon Postgres + pgvector) ---
# Pooled connection (runtime / serverless)
DATABASE_URL=
# Direct/unpooled connection (migrations)
DATABASE_URL_UNPOOLED=

# --- Storage (Vercel Blob) ---
BLOB_READ_WRITE_TOKEN=

# --- AI ---
# LLM para respuestas grounded (Claude)
ANTHROPIC_API_KEY=
# Embeddings (text-embedding-3-small, 1536 dims)
OPENAI_API_KEY=

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
